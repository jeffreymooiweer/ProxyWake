# Dependencies & build output (rebuilt inside container)
frontend/node_modules
frontend/build

# Python cache & local data
backend/__pycache__
backend/**/*.pyc
backend/data
backend/devices.db
backend/app.log
backend/api_keys.json
backend/password.hash

# Git & IDE
.git
.gitignore
.github

# Docs & local env (not needed in image)
README.md
LICENSE
*.md
.env
.env.*

# Docker compose files (not needed in build context)
docker-compose.yml
docker/
