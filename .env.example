# ProxyWake environment variables (Docker Compose)

# Copy to .env and edit:
# cp .env.example .env

# Web UI password (strongly recommended in production)
PROXYWAKE_PASSWORD=ChangeMeNow

# Optional: fixed API key for reverse proxy integration
# PROXYWAKE_API_KEY=

# Optional: stable session / credential encryption key
# PROXYWAKE_SECRET_KEY=

# Optional: comma-separated CORS origins
# PROXYWAKE_ALLOWED_ORIGINS=

# Set to true when the UI is only served over HTTPS
# PROXYWAKE_SESSION_COOKIE_SECURE=true

# Host port mapped to container 5001 (default 8462)
PROXYWAKE_PORT=8462

# Optional: pin Docker image tag (default: latest)
# PROXYWAKE_IMAGE=jeffersonmouze/proxywake:4.2.5
