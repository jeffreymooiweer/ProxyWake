# Kopieer naar .env en pas aan:
# cp .env.example .env

# Wachtwoord voor de webinterface (aanbevolen)
PROXYWAKE_PASSWORD=SterkWachtwoord123

# Optioneel: vaste API-sleutel voor NPM
# PROXYWAKE_API_KEY=

# Optioneel: Flask sessiesleutel
# PROXYWAKE_SECRET_KEY=

# Host-poort (standaard 8462)
PROXYWAKE_PORT=8462
